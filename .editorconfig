# Top-level EditorConfig file
root = true

# Global defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown, JSONC, YAML, TOML — keep trailing whitespace (e.g., for lists)
[*.md]
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[*.jsonc]
indent_size = 2

[*.yaml]
indent_size = 2

[*.yml]
indent_size = 2

[*.toml]
indent_size = 2

# Makefiles — tabs are mandatory
[Makefile]
indent_style = tab

# Shell scripts, Dockerfiles, ini/cfg
[*.sh]
indent_style = space
indent_size = 2

[*.cfg]
indent_style = space
indent_size = 2

[*.ini]
indent_style = space
indent_size = 2

[Dockerfile*]
indent_style = space
indent_size = 2

# TypeScript/JavaScript
[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2

[*.js]
indent_size = 2

[*.jsx]
indent_size = 2

# Python
[*.py]
indent_size = 4

# PowerShell
[*.ps1]
indent_size = 2
