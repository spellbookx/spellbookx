{
  "[dotenv]": {
    "editor.defaultFormatter": "mikestead.dotenv"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[ini]": {
    "editor.defaultFormatter": "redhat.vscode-ini"
  },
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "[properties]": {
    "editor.defaultFormatter": "jasonlhy.vscode-properties-sorter"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "files.associations": {
    ".czrc": "json",
    ".dockerignore": "ignore",
    ".editorconfig": "editorconfig",
    ".env*": "dotenv",
    ".gitattributes": "gitattributes",
    ".gitignore": "gitignore",
    ".gitlab-ci.yml": "yaml",
    ".npmrc": "ini",
    ".nvmrc": "plaintext",
    "*.bash": "shellscript",
    "*.bat": "bat",
    "*.cfg": "ini",
    "*.cmd": "bat",
    "*.conf": "ini",
    "*.css": "css",
    "*.csv": "csv",
    "*.db": "sqlite",
    "*.env": "dotenv",
    "*.fish": "fish",
    "*.htm": "html",
    "*.html": "html",
    "*.ini": "ini",
    "*.ipynb": "jupyter",
    "*.js": "javascript",
    "*.json": "json",
    "*.properties": "properties",
    "*.jsonc": "jsonc",
    "*.jsx": "javascriptreact",
    "*.less": "less",
    "*.log": "log",
    "*.md": "markdown",
    "*.ps1": "powershell",
    "*.pxd": "cython",
    "*.py": "python",
    "*.pyd": "python",
    "*.pyw": "python",
    "*.pyx": "cython",
    "*.rst": "restructuredtext",
    "*.scss": "scss",
    "*.sh": "shellscript",
    "*.sql": "sql",
    "*.sqlite": "sqlite",
    "*.svg": "xml",
    "*.tex": "latex",
    "*.toml": "toml",
    "*.ts": "typescript",
    "*.tsv": "tsv",
    "*.tsx": "typescriptreact",
    "*.vue": "vue",
    "*.xhtml": "html",
    "*.xml": "xml",
    "*.yaml": "yaml",
    "*.yml": "yaml",
    "*.zsh": "shellscript",
    "docker-compose.yml": "yaml",
    "Dockerfile": "dockerfile",
    "Dockerfile*": "dockerfile",
    "Jenkinsfile": "groovy",
    "LICENSE": "plaintext",
    "Makefile": "makefile",
    "Pipfile": "pipfile",
    "Pipfile.lock": "json",
    "pnpm-lock.yaml": "yaml",
    "pnpm-workspace.yaml": "yaml",
    "poetry.lock": "toml",
    "pyproject.toml": "toml",
    "requirements-*.txt": "pip-requirements",
    "requirements.txt": "pip-requirements"
  },
  "json.schemas": [
    {
      "fileMatch": [".czrc"],
      "url": "https://json.schemastore.org/czrc.json"
    },
    {
      "fileMatch": ["pyproject.toml"],
      "url": "https://json.schemastore.org/pyproject.json"
    },
    {
      "fileMatch": ["Pipfile"],
      "url": "https://json.schemastore.org/pipfile.json"
    },
    {
      "fileMatch": ["Pipfile.lock"],
      "url": "https://json.schemastore.org/pipfile-lock.json"
    },
    {
      "fileMatch": [
        "package.json",
        "package-lock.json",
        ".eslintrc.json",
        ".babelrc",
        ".babelrc.json",
        "babel.config.json",
        "jsconfig.json",
        "tsconfig.json",
        "tslint.json",
        ".prettierrc",
        ".prettierrc.json",
        "lerna.json",
        "typedoc.json"
      ],
      "url": "http://json.schemastore.org/package"
    },
    {
      "fileMatch": [
        "renovate.json",
        "renovate.json5",
        ".renovaterc",
        ".renovaterc.json"
      ],
      "url": "https://docs.renovatebot.com/renovate-schema.json"
    }
  ],
  "yaml.schemas": {
    "https://json.schemastore.org/docker-compose.json": [
      "docker-compose.yml",
      "docker-compose.*.yml",
      "compose.yml",
      "compose.*.yml"
    ],
    "https://json.schemastore.org/github-workflow.json": [
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml"
    ],
    "https://json.schemastore.org/lefthook.json": ["lefthook.yml"],
    "https://json.schemastore.org/pnpm-workspace.json": ["pnpm-workspace.yaml"]
  }
}
